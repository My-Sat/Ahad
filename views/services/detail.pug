extends ../layout

block content
  .d-none(data-main-width='wide')
  - const pricingMode = service && service.pricingMode === 'large_format' ? 'large_format' : 'price_rules'
  - const largeMaterialId = service && service.largeFormatMaterial ? String(service.largeFormatMaterial._id || service.largeFormatMaterial) : ''
  // header row: title + back link + small inline requires-printer toggle form
  .d-flex.justify-content-between.align-items-center.mb-3
    .d-flex.align-items-center.g-3
      h2.mb-0= service.name
      // small inline form to configure this service pricing mode
      form#serviceSettingsForm.d-flex.align-items-center.ms-3.gap-2.flex-wrap(method='post', action=`/admin/services/${service._id}?_method=PUT`)
        label.form-label.small.mb-0(for='servicePricingMode') Select Service type
        select.form-select.form-select-sm(name='pricingMode', id='servicePricingMode', style='width:150px;')
          option(value='price_rules', selected=pricingMode === 'price_rules') Price Rules
          option(value='large_format', selected=pricingMode === 'large_format') Large Format
        .form-check.me-1
          input.form-check-input(type='checkbox', id='requiresPrinter', name='requiresPrinter', checked=pricingMode === 'large_format' || (service && service.requiresPrinter), disabled=pricingMode === 'large_format')
          label.form-check-label(for='requiresPrinter') Requires printer
        button.btn.btn-sm.btn-secondary(type='submit') Save Settings

    a.btn.btn-secondary(href='/admin/services') Back

  hr

  //- Large Format configuration. Hidden when this service uses normal price rules.
  #largeFormatConfigPanel.content-card(style=pricingMode === 'large_format' ? null : 'display:none;')
    .dark-card-body
      .d-flex.justify-content-between.align-items-center.flex-wrap.gap-2.mb-3
        div
          h5.mb-1 Large Format Pricing
          small.text-muted-light Large Format is always printer-required. Jobs use Length x Breadth x QTY.
      .row.g-2.align-items-end
        .col-md-4
          label.form-label(for='largeFormatRateInput') Amount per Square Feet
          .input-group
            span.input-group-text GH₵ / sq ft
            input.form-control(type='number', step='0.01', min='0', name='largeFormatRate', id='largeFormatRateInput', form='serviceSettingsForm', value=(service && service.largeFormatRate != null ? Number(service.largeFormatRate).toFixed(2) : ''), placeholder='0.00')
        .col-md-4
          label.form-label(for='largeFormatMaterialInput') Stock material consumed
          select.form-select(name='largeFormatMaterialId', id='largeFormatMaterialInput', form='serviceSettingsForm')
            option(value='') -- Select material --
            if materials && materials.length
              each m in materials
                option(value=m._id, selected=largeMaterialId === String(m._id)) #{m.name} (#{m.baseUnitName || 'base unit'})
          small.text-muted-light Only standalone catalogue materials are listed here.
        .col-md-2
          label.form-label(for='largeFormatWasteInput') Waste %
          input.form-control(type='number', step='0.01', min='0', max='100', name='largeFormatWastePercent', id='largeFormatWasteInput', form='serviceSettingsForm', value=(service && service.largeFormatWastePercent != null ? Number(service.largeFormatWastePercent).toFixed(2) : '0.00'), placeholder='0')
        .col-md-2
          label.form-label(for='largeFormatMinimumInput') Min sq ft
          input.form-control(type='number', step='0.0001', min='0', name='largeFormatMinimumSquareFeet', id='largeFormatMinimumInput', form='serviceSettingsForm', value=(service && service.largeFormatMinimumSquareFeet != null ? Number(service.largeFormatMinimumSquareFeet).toFixed(4).replace(/\.?0+$/, '') : '0'), placeholder='0')
        .col-md-5
          .alert.alert-info.mb-0
            strong Current:
            |  GH₵ #{service && service.largeFormatRate != null ? Number(service.largeFormatRate).toFixed(2) : '0.00'} per square feet
            if service && service.largeFormatMaterial
              br
              span Material: #{service.largeFormatMaterial.name || 'Configured material'}
            br
            span Stock consumed: calculated sq ft + waste %, rounded to 4 decimals.
        .col-auto
          button#saveLargeFormatBtn.btn.btn-secondary(type='submit', form='serviceSettingsForm') Save Large Format

  //- Units accordion (now inside a dark surface container)
  // wrapping the accordion in .content-card/.dark-card-body ensures our dark styles apply
  #priceRulesUnitsPanel.content-card(style=pricingMode === 'large_format' ? 'display:none;' : null)
    .dark-card-body
      #unitsAccordion.accordion.mb-4
        if !service.components || service.components.length === 0
          .alert.alert-info No components available. Add units and sub-units first.
        else
          each comp, idx in service.components
            - const unit = comp.unit
            - const panelId = `unitPanel-${idx}`
            .accordion-item
              h2.accordion-header(id=`heading-${panelId}`)
                .d-flex.align-items-center
                  button.accordion-button.collapsed.flex-grow-1(type='button', data-bs-toggle='collapse', data-bs-target=`#collapse-${panelId}`, aria-expanded='false', aria-controls=`collapse-${panelId}`)
                    .d-flex.justify-content-between.w-100
                      span.unit-name #{unit && unit.name ? unit.name : 'Unit'}
                      small.text-muted.ms-2 #{ (comp.subUnits && comp.subUnits.length) ? comp.subUnits.length + ' sub-units' : '0 sub-units' }
                  .btn-group.btn-group-sm.ms-2(role='group', aria-label='Arrange unit')
                    button.btn.btn-outline-light-custom.move-unit-btn-detail(
                      type='button',
                      data-unit-id=unit._id,
                      data-direction='up',
                      title='Move unit up'
                    )
                      i.bi.bi-chevron-up
                    button.btn.btn-outline-light-custom.move-unit-btn-detail(
                      type='button',
                      data-unit-id=unit._id,
                      data-direction='down',
                      title='Move unit down'
                    )
                      i.bi.bi-chevron-down

              .accordion-collapse.collapse(id=`collapse-${panelId}`)
                .accordion-body
                  ul.list-group
                    each su in comp.subUnits
                      - const subId = (typeof su === 'object') ? su._id : su
                      - const subName = (typeof su === 'object') ? (su.name || subId) : subId
                      li.list-group-item.d-flex.align-items-center
                        label.form-check.mb-0.d-flex.align-items-center.w-100
                          input.form-check-input.unit-sub-checkbox.me-2(type='checkbox', data-unit=unit._id, data-subunit=subId)
                          span.flex-grow-1= subName

  //- Price assignment (placed in a content-card so inputs/dropdowns follow dark styles)
  #priceRulesAssignPanel.content-card.mt-3(style=pricingMode === 'large_format' ? 'display:none;' : null)
    .dark-card-body
      form#assign-price(method='post', action=`/admin/services/${service._id}/prices`, class='mb-4 needs-validation', novalidate, data-disable-spinner='true')
        input(type='hidden', name='selections', id='selectionsInput')
        .row.g-2.align-items-center
          .col-md-5
            .input-group
              input.form-control(type='text', name='customLabel', id='customLabelInput', placeholder='Optional short rule name (e.g. Banner 3x4)')
          .col-md-2
            select.form-select(name='priceTarget', id='priceTargetInput')
              option(value='customer' selected) Customers
              option(value='artist') Artist
              option(value='organisation') Organisation
          .col-auto
            label.form-label(for='priceInput') Price (GH₵)
          .col-md-3
            .input-group
              input.form-control(type='number', step='0.01', name='price', id='priceInput', required, placeholder='0.00')
          .col-md-2
            .input-group
              input.form-control(type='number', step='0.01', name='price2', id='price2Input', placeholder='F/B price (optional)')
              span.input-group-text.small F/B
          .col-auto
            button.btn.btn-secondary(type='submit', id='assignBtn')
              span.spinner-border.spinner-border-sm.me-2(role='status', aria-hidden='true', id='assignSpinner', style='display:none;')
              | Assign Price
          .col-auto
            small.text-muted Select one sub-unit per relevant unit, then click Assign.

  hr

  //- Prices section (also inside content-card to style the table/thead/tbody)
  #priceRulesExistingPanel.content-card.mt-3(style=pricingMode === 'large_format' ? 'display:none;' : null)
    .dark-card-body
      #pricesSection
        h5.mb-2 Existing Price Rules
        if prices && prices.length
          table.table.table-striped.table-hover.table-sm
            thead
              tr
                th Selection(s)
                th.text-end Price
                th.text-end F/B
                th.text-center Actions
            tbody
              each p in prices
                - const ruleSelectionText = (Array.isArray(p.selections) ? p.selections.map(s => `${(s && s.unit && s.unit.name) ? s.unit.name : ''} ${(s && s.subUnit && s.subUnit.name) ? s.subUnit.name : ''}`).join(' ') : '')
                - const ruleHintText = `${ruleSelectionText} ${p.selectionLabel || ''} ${p.customLabel || ''}`.trim()
                - const isBwRule = /(?:\bb\/w\b|black\s*and\s*white|monochrome|\bmono\b|\bbw\b)/i.test(ruleHintText)
                - const isColorRule = !isBwRule && /(?:\bcolour\b|\bcolor\b|\bc\/l\b|\bcol\b)/i.test(ruleHintText)
                tr(data-price-id=p._id, class=isColorRule ? 'table-danger' : '')
                  td
                    if isColorRule
                      span.badge.text-bg-danger.me-2 Color
                    else if isBwRule
                      span.badge.text-bg-secondary.me-2 B/W
                    if p.selectionLabel
                      span(class=isColorRule ? 'text-danger fw-semibold' : '')= p.selectionLabel
                    else if p.selections && p.selections.length
                      - var len = p.selections.length
                      each s, i in p.selections
                        - var unitName = s.unit && s.unit.name ? s.unit.name : (s.unit ? String(s.unit) : '');
                        - var subName = s.subUnit && s.subUnit.name ? s.subUnit.name : (s.subUnit ? String(s.subUnit) : '');
                        span.me-1(class=isColorRule ? 'text-danger fw-semibold' : '') #{unitName}: #{subName}
                        if i != len - 1
                          |  +
                    else
                      | (no label)
                  td.text-end= (typeof p.price === 'number') ? p.price.toFixed(2) : p.price
                  td.text-end
                    if p.price2 !== undefined && p.price2 !== null
                      = (typeof p.price2 === 'number') ? p.price2.toFixed(2) : p.price2
                    else
                      span.text-muted small N/A
                  td.text-center
                    .dropdown.d-inline-block
                      button.btn.btn-sm.btn-light.dropdown-toggle(type='button', id=`priceMenuBtn-${p._id}`, data-bs-toggle='dropdown', aria-expanded='false', aria-haspopup='true', title='Actions')
                        span.visually-hidden Actions
                      ul.dropdown-menu.dropdown-menu-end(aria-labelledby=`priceMenuBtn-${p._id}`)
                        li
                          button.dropdown-item.edit-price-btn(
                            type='button',
                            data-price-id=p._id,
                            data-customer-price=(typeof p.price === 'number' ? p.price.toFixed(2) : p.price),
                            data-customer-price2=(typeof p.price2 === 'number' ? p.price2.toFixed(2) : (p.price2 ? p.price2 : '')),
                            data-artist-price=(p.categoryPrices && p.categoryPrices.artist && p.categoryPrices.artist.price != null ? Number(p.categoryPrices.artist.price).toFixed(2) : ''),
                            data-artist-price2=(p.categoryPrices && p.categoryPrices.artist && p.categoryPrices.artist.price2 != null ? Number(p.categoryPrices.artist.price2).toFixed(2) : ''),
                            data-organisation-price=(p.categoryPrices && p.categoryPrices.organisation && p.categoryPrices.organisation.price != null ? Number(p.categoryPrices.organisation.price).toFixed(2) : ''),
                            data-organisation-price2=(p.categoryPrices && p.categoryPrices.organisation && p.categoryPrices.organisation.price2 != null ? Number(p.categoryPrices.organisation.price2).toFixed(2) : ''),
                            data-selection-label=(p.selectionLabel || ''),
                            data-custom-label=(p.customLabel || '')
                          )
                            i.bi.bi-pencil.me-2
                            | Edit
                        li
                          button.dropdown-item.open-delete-price(type='button', data-price-id=p._id)
                            i.bi.bi-trash.me-2
                            | Delete
        else
          .alert.alert-info.mb-0 No price rules created yet.
  // Keep Service Detail scripts inside #main-content so dashboard_nav AJAX loads them
  script(src='/javascripts/service_detail.js')
  script.
    (function () {
      function syncLargeFormatMode() {
        var mode = document.getElementById('servicePricingMode');
        var rate = document.getElementById('largeFormatRateInput');
        var material = document.getElementById('largeFormatMaterialInput');
        var waste = document.getElementById('largeFormatWasteInput');
        var minimum = document.getElementById('largeFormatMinimumInput');
        var printer = document.getElementById('requiresPrinter');
        var largePanel = document.getElementById('largeFormatConfigPanel');
        var pricePanels = [
          document.getElementById('priceRulesUnitsPanel'),
          document.getElementById('priceRulesAssignPanel'),
          document.getElementById('priceRulesExistingPanel')
        ];
        var isLarge = !!(mode && mode.value === 'large_format');
        if (rate) rate.disabled = !isLarge;
        if (material) material.disabled = !isLarge;
        if (waste) waste.disabled = !isLarge;
        if (minimum) minimum.disabled = !isLarge;
        if (printer) {
          printer.disabled = isLarge;
          if (isLarge) printer.checked = true;
        }
        if (largePanel) largePanel.style.display = isLarge ? '' : 'none';
        pricePanels.forEach(function (panel) {
          if (panel) panel.style.display = isLarge ? 'none' : '';
        });
      }
      document.addEventListener('change', function (e) {
        if (e.target && e.target.id === 'servicePricingMode') syncLargeFormatMode();
      });
      document.addEventListener('ajax:page:loaded', syncLargeFormatMode);
      syncLargeFormatMode();
    })();
