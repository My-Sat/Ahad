extends ../layout

block content
  .container
    .d-none(data-main-width='wide')
    .row
      .col-12
        .card.shadow-sm.dark-surface
          .card-body.dark-card-body#accountingPage
            .d-flex.justify-content-between.align-items-center.mb-3
              div
                h4.mb-0.text-white Accounting
                p.text-muted-light.small.mb-0 Accrual accounting for revenue, stock cost, fixed assets, and manual expenses.

            ul.nav.nav-tabs.mb-3(role='tablist')
              li.nav-item(role='presentation')
                button.nav-link.active(type='button', data-bs-toggle='tab', data-bs-target='#tabProfitLoss') Profit & Loss
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#tabManualExpenses') Manual Expenses
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#tabAccruedExpenses') Accrued Expenses
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#tabPrepaidExpenses') Prepaid Expenses
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#tabFixedAssets') Fixed Assets
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#tabJournal') Journal

            .tab-content
              #tabProfitLoss.tab-pane.fade.show.active
                .d-flex.gap-2.align-items-end.mb-3
                  div
                    label.form-label.small.text-muted-light(for='accountingFrom') From
                    input.form-control.form-control-sm.form-control-dark#accountingFrom(type='date', value=defaultFrom)
                  div
                    label.form-label.small.text-muted-light(for='accountingTo') To
                    input.form-control.form-control-sm.form-control-dark#accountingTo(type='date', value=defaultTo)
                  button.btn.btn-primary.btn-sm#loadProfitLossBtn(type='button') Load P&L
                .row.g-2.mb-3
                  .col-6.col-lg-2
                    .card.dark-surface.border-0
                      .card-body.p-2.dark-card-body
                        div.small.text-muted-light Revenue
                        strong#plRevenue GH₵ 0.00
                  .col-6.col-lg-2
                    .card.dark-surface.border-0
                      .card-body.p-2.dark-card-body
                        div.small.text-muted-light Cost of Sales
                        strong#plCogs GH₵ 0.00
                  .col-6.col-lg-2
                    .card.dark-surface.border-0
                      .card-body.p-2.dark-card-body
                        div.small.text-muted-light Gross Profit
                        strong#plGross GH₵ 0.00
                  .col-6.col-lg-3
                    .card.dark-surface.border-0
                      .card-body.p-2.dark-card-body
                        div.small.text-muted-light Operating Expenses
                        strong#plOperating GH₵ 0.00
                  .col-6.col-lg-3
                    .card.dark-surface.border-0
                      .card-body.p-2.dark-card-body
                        div.small.text-muted-light Net Profit / Loss
                        strong#plNet GH₵ 0.00
                .row.g-3
                  .col-lg-4
                    h6.text-white Revenue
                    table.table.table-sm#plRevenueTable
                      tbody
                        tr
                          td.text-muted Loading...
                  .col-lg-4
                    h6.text-white Cost of Sales
                    table.table.table-sm#plCogsTable
                      tbody
                        tr
                          td.text-muted Loading...
                  .col-lg-4
                    h6.text-white Operating Expenses
                    table.table.table-sm#plOperatingTable
                      tbody
                        tr
                          td.text-muted Loading...

              #tabManualExpenses.tab-pane.fade
                .row.g-3
                  .col-lg-4
                    h6.text-white Record Manual Expense
                    form#manualExpenseForm(data-disable-spinner='true')
                      .mb-2
                        label.form-label.text-muted-light(for='manualExpenseDescription') Description
                        input.form-control.form-control-dark#manualExpenseDescription(type='text', required)
                      .mb-2
                        label.form-label.text-muted-light(for='manualExpenseCategory') Category
                        select.form-select.form-select-dark#manualExpenseCategory
                          each cat in categories
                            option(value=cat._id)= cat.name
                      .row.g-2
                        .col-6
                          label.form-label.text-muted-light(for='manualExpenseAmount') Amount
                          input.form-control.form-control-dark#manualExpenseAmount(type='number', min='0.01', step='0.01', required)
                        .col-6
                          label.form-label.text-muted-light(for='manualExpenseDate') Date
                          input.form-control.form-control-dark#manualExpenseDate(type='date', value=defaultTo)
                      .mb-2.mt-2
                        label.form-label.text-muted-light(for='manualExpenseTreatment') Treatment
                        select.form-select.form-select-dark#manualExpenseTreatment
                          option(value='expense' selected) Expense paid now
                          option(value='accrued') Expense accrued/unpaid
                          option(value='prepaid') Prepaid asset
                      .card.dark-surface.border-secondary.mb-2.d-none#manualExpenseAutoReleaseWrap
                        .card-body.p-2
                          .form-check.form-switch.mb-2
                            input.form-check-input#manualExpenseAutoRelease(type='checkbox')
                            label.form-check-label.text-muted-light(for='manualExpenseAutoRelease') Auto release monthly
                          .row.g-2.align-items-end
                            .col-6
                              label.form-label.text-muted-light(for='manualExpenseReleaseMonths') Number of months
                              input.form-control.form-control-dark#manualExpenseReleaseMonths(type='number', min='1', step='1', placeholder='e.g. 6')
                            .col-6
                              small.text-muted-light#manualExpenseAutoReleaseHint Manual release remains available.
                      .mb-2#manualExpenseCashBookWrap
                        label.form-label.text-muted-light(for='manualExpenseCashBook') Cash book
                        select.form-select.form-select-dark#manualExpenseCashBook
                          option(value='') Select cash book
                          each book in cashBooks
                            option(value=book._id data-kind=book.kind)= `${book.name} (${book.kind === 'momo' ? 'MoMo' : (book.kind === 'bank' ? 'Bank' : 'Cash')})`
                      .row.g-2.d-none#manualExpenseMomoWrap
                        .col-6
                          label.form-label.text-muted-light(for='manualExpenseMomoNumber') MoMo number
                          input.form-control.form-control-dark#manualExpenseMomoNumber(type='text')
                        .col-6
                          label.form-label.text-muted-light(for='manualExpenseMomoTxId') Transaction ID
                          input.form-control.form-control-dark#manualExpenseMomoTxId(type='text')
                      .row.g-2.d-none#manualExpenseBankWrap
                        .col-6
                          label.form-label.text-muted-light(for='manualExpenseChequeNumber') Cheque number
                          input.form-control.form-control-dark#manualExpenseChequeNumber(type='text')
                        .col-6
                          label.form-label.text-muted-light(for='manualExpenseDepositDetails') Deposit details
                          input.form-control.form-control-dark#manualExpenseDepositDetails(type='text')
                      button.btn.btn-primary#saveManualExpenseBtn(type='submit') Save Expense
                      p.small.mt-2#manualExpenseStatus
                  .col-lg-8
                    h6.text-white Recent Manual Expenses
                    .table-responsive
                      table.table.table-sm.table-hover#manualExpensesTable
                        thead
                          tr
                            th Date
                            th Description
                            th Category
                            th Treatment
                            th.text-end Amount
                        tbody
                          if expenses && expenses.length
                            each e in expenses
                              tr
                                td #{e.date ? new Date(e.date).toLocaleDateString() : ''}
                                td= e.description
                                td= e.categoryName
                                td= e.treatment
                                td.text-end GH₵ #{Number(e.amount || 0).toFixed(2)}
                          else
                            tr
                              td.text-muted(colspan='5') No manual expenses yet.

              #tabAccruedExpenses.tab-pane.fade
                .row.g-3
                  .col-lg-4
                    h6.text-white Pay Accrued Expense
                    form#accruedPaymentForm(data-disable-spinner='true')
                      .mb-2
                        label.form-label.text-muted-light(for='accruedExpenseSelect') Accrued item
                        select.form-select.form-select-dark#accruedExpenseSelect(required)
                          option(value='') Select accrued expense
                          each a in accruedExpenses
                            if Number(a.remainingAmount || 0) > 0
                              option(value=a._id data-remaining=Number(a.remainingAmount || 0).toFixed(2)) #{a.description} - remaining GH₵ #{Number(a.remainingAmount || 0).toFixed(2)}
                      .row.g-2
                        .col-6
                          label.form-label.text-muted-light(for='accruedPaymentAmount') Payment amount
                          input.form-control.form-control-dark#accruedPaymentAmount(type='number', min='0.01', step='0.01', required)
                        .col-6
                          label.form-label.text-muted-light(for='accruedPaymentDate') Payment date
                          input.form-control.form-control-dark#accruedPaymentDate(type='date', value=defaultTo)
                      .mb-2.mt-2
                        label.form-label.text-muted-light(for='accruedPaymentCashBook') Cash book
                        select.form-select.form-select-dark#accruedPaymentCashBook(required)
                          option(value='') Select cash book
                          each book in cashBooks
                            option(value=book._id data-kind=book.kind)= `${book.name} (${book.kind === 'momo' ? 'MoMo' : (book.kind === 'bank' ? 'Bank' : 'Cash')})`
                      .row.g-2.d-none#accruedPaymentMomoWrap
                        .col-6
                          label.form-label.text-muted-light(for='accruedPaymentMomoNumber') MoMo number
                          input.form-control.form-control-dark#accruedPaymentMomoNumber(type='text')
                        .col-6
                          label.form-label.text-muted-light(for='accruedPaymentMomoTxId') Transaction ID
                          input.form-control.form-control-dark#accruedPaymentMomoTxId(type='text')
                      .row.g-2.d-none#accruedPaymentBankWrap
                        .col-6
                          label.form-label.text-muted-light(for='accruedPaymentChequeNumber') Cheque number
                          input.form-control.form-control-dark#accruedPaymentChequeNumber(type='text')
                        .col-6
                          label.form-label.text-muted-light(for='accruedPaymentDepositDetails') Payment details
                          input.form-control.form-control-dark#accruedPaymentDepositDetails(type='text')
                      .mb-2.mt-2
                        label.form-label.text-muted-light(for='accruedPaymentNote') Note
                        input.form-control.form-control-dark#accruedPaymentNote(type='text', placeholder='e.g. Salary paid')
                      button.btn.btn-outline-primary#accruedPaymentBtn(type='submit') Pay Accrued
                      p.small.mt-2#accruedPaymentStatus
                  .col-lg-8
                    h6.text-white Accrued Payables
                    .table-responsive.mb-3
                      table.table.table-sm.table-hover#accruedExpensesTable
                        thead
                          tr
                            th Date
                            th Description
                            th Category
                            th.text-end Original
                            th.text-end Paid
                            th.text-end Remaining
                            th.text-end Posting
                        tbody
                          if accruedExpenses && accruedExpenses.length
                            each a in accruedExpenses
                              tr
                                td #{a.date ? new Date(a.date).toLocaleDateString() : ''}
                                td= a.description
                                td= a.categoryName
                                td.text-end GH₵ #{Number(a.amount || 0).toFixed(2)}
                                td.text-end GH₵ #{Number(a.paidAmount || 0).toFixed(2)}
                                td.text-end GH₵ #{Number(a.remainingAmount || 0).toFixed(2)}
                                td.text-end
                                  if Number(a.remainingAmount || 0) > 0
                                    button.btn.btn-outline-light-custom.btn-sm.use-accrued-payment-btn(type='button', data-accrued-id=a._id, data-remaining=Number(a.remainingAmount || 0).toFixed(2), data-description=a.description) Pay
                                  else
                                    span.badge.bg-success Paid
                          else
                            tr
                              td.text-muted(colspan='7') No accrued expenses yet.
                    h6.text-white Recent Accrued Payments
                    .table-responsive
                      table.table.table-sm.table-hover#accruedPaymentsTable
                        thead
                          tr
                            th Date
                            th Description
                            th Category
                            th Cash Book
                            th Note
                            th.text-end Amount
                        tbody
                          if accruedPayments && accruedPayments.length
                            each p in accruedPayments
                              tr
                                td #{p.date ? new Date(p.date).toLocaleDateString() : ''}
                                td= p.description
                                td= p.categoryName
                                td= p.cashBookName
                                td= p.note
                                td.text-end GH₵ #{Number(p.amount || 0).toFixed(2)}
                          else
                            tr
                              td.text-muted(colspan='6') No accrued payments yet.

              #tabPrepaidExpenses.tab-pane.fade
                .row.g-3
                  .col-lg-4
                    h6.text-white Release Prepaid Expense
                    form#prepaidReleaseForm(data-disable-spinner='true')
                      .mb-2
                        label.form-label.text-muted-light(for='prepaidExpenseSelect') Prepaid item
                        select.form-select.form-select-dark#prepaidExpenseSelect(required)
                          option(value='') Select prepaid expense
                          each p in prepaids
                            if Number(p.remainingAmount || 0) > 0
                              option(value=p._id data-remaining=Number(p.remainingAmount || 0).toFixed(2)) #{p.description} - remaining GH₵ #{Number(p.remainingAmount || 0).toFixed(2)}
                      .row.g-2
                        .col-6
                          label.form-label.text-muted-light(for='prepaidReleaseAmount') Release amount
                          input.form-control.form-control-dark#prepaidReleaseAmount(type='number', min='0.01', step='0.01', required)
                        .col-6
                          label.form-label.text-muted-light(for='prepaidReleaseDate') Release date
                          input.form-control.form-control-dark#prepaidReleaseDate(type='date', value=defaultTo)
                      .mb-2.mt-2
                        label.form-label.text-muted-light(for='prepaidReleaseNote') Note
                        input.form-control.form-control-dark#prepaidReleaseNote(type='text', placeholder='e.g. May rent release')
                      button.btn.btn-outline-primary#savePrepaidReleaseBtn(type='submit') Release To Expense
                      p.small.mt-2#prepaidReleaseStatus
                  .col-lg-8
                    h6.text-white Prepaid Balances
                    .table-responsive.mb-3
                      table.table.table-sm.table-hover#prepaidExpensesTable
                        thead
                          tr
                            th Date
                            th Description
                            th Category
                            th.text-end Original
                            th.text-end Released
                            th.text-end Remaining
                            th Release
                            th.text-end Action
                        tbody
                          if prepaids && prepaids.length
                            each p in prepaids
                              tr
                                td #{p.date ? new Date(p.date).toLocaleDateString() : ''}
                                td= p.description
                                td= p.categoryName
                                td.text-end GH₵ #{Number(p.amount || 0).toFixed(2)}
                                td.text-end GH₵ #{Number(p.releasedAmount || 0).toFixed(2)}
                                td.text-end GH₵ #{Number(p.remainingAmount || 0).toFixed(2)}
                                td
                                  if p.autoReleaseEnabled
                                    span.badge.bg-info.text-dark Auto #{Number(p.releaseMonths || 0)} mo.
                                  else
                                    span.badge.bg-secondary Manual
                                td.text-end
                                  if Number(p.remainingAmount || 0) > 0
                                    button.btn.btn-outline-light-custom.btn-sm.use-prepaid-release-btn(type='button', data-prepaid-id=p._id, data-remaining=Number(p.remainingAmount || 0).toFixed(2), data-description=p.description) Release
                                  else
                                    span.badge.bg-success Fully released
                          else
                            tr
                              td.text-muted(colspan='8') No prepaid expenses yet.
                    h6.text-white Recent Releases
                    .table-responsive
                      table.table.table-sm.table-hover#prepaidReleasesTable
                        thead
                          tr
                            th Date
                            th Description
                            th Category
                            th Note
                            th.text-end Amount
                        tbody
                          if prepaidReleases && prepaidReleases.length
                            each r in prepaidReleases
                              tr
                                td #{r.date ? new Date(r.date).toLocaleDateString() : ''}
                                td= r.description
                                td= r.categoryName
                                td= r.note
                                td.text-end GH₵ #{Number(r.amount || 0).toFixed(2)}
                          else
                            tr
                              td.text-muted(colspan='5') No prepaid releases yet.

              #tabFixedAssets.tab-pane.fade
                .row.g-3
                  .col-lg-4
                    h6.text-white Create Fixed Asset
                    form#fixedAssetForm(data-disable-spinner='true')
                      .mb-2
                        label.form-label.text-muted-light(for='fixedAssetName') Name
                        input.form-control.form-control-dark#fixedAssetName(type='text', placeholder='e.g. Canon Printer', required)
                      .mb-2
                        label.form-label.text-muted-light(for='fixedAssetPrinter') Linked printer
                        select.form-select.form-select-dark#fixedAssetPrinter
                          option(value='') Not linked
                          each p in printers
                            option(value=p._id)= p.name
                      .row.g-2
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetCost') Purchase cost
                          input.form-control.form-control-dark#fixedAssetCost(type='number', min='0.01', step='0.01', required)
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetResidual') Residual value
                          input.form-control.form-control-dark#fixedAssetResidual(type='number', min='0', step='0.01', value='0')
                      .row.g-2.mt-1
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetMethod') Depreciation
                          select.form-select.form-select-dark#fixedAssetMethod
                            option(value='usage' selected) Usage based
                            option(value='straight_line') Straight line
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetDate') Purchase date
                          input.form-control.form-control-dark#fixedAssetDate(type='date', value=defaultTo)
                      .row.g-2.mt-1
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetUnits') Useful life units
                          input.form-control.form-control-dark#fixedAssetUnits(type='number', min='0', step='1', placeholder='e.g. 1000000')
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetMonths') Useful life months
                          input.form-control.form-control-dark#fixedAssetMonths(type='number', min='0', step='1')
                      p.small.text-muted-light.mt-2.mb-0 Usage based posts when the linked printer is used. Straight line posts automatically once per month.
                      .mb-2.mt-2
                        label.form-label.text-muted-light(for='fixedAssetCashBook') Cash book used
                        select.form-select.form-select-dark#fixedAssetCashBook
                          option(value='') Bought on credit / unpaid
                          each book in cashBooks
                            option(value=book._id data-kind=book.kind)= `${book.name} (${book.kind === 'momo' ? 'MoMo' : (book.kind === 'bank' ? 'Bank' : 'Cash')})`
                      .row.g-2.d-none#fixedAssetMomoWrap
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetMomoNumber') MoMo number
                          input.form-control.form-control-dark#fixedAssetMomoNumber(type='text')
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetMomoTxId') Transaction ID
                          input.form-control.form-control-dark#fixedAssetMomoTxId(type='text')
                      .row.g-2.d-none#fixedAssetBankWrap
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetChequeNumber') Cheque number
                          input.form-control.form-control-dark#fixedAssetChequeNumber(type='text')
                        .col-6
                          label.form-label.text-muted-light(for='fixedAssetDepositDetails') Deposit details
                          input.form-control.form-control-dark#fixedAssetDepositDetails(type='text')
                      .mb-2
                        label.form-label.text-muted-light(for='fixedAssetNote') Note
                        input.form-control.form-control-dark#fixedAssetNote(type='text')
                      button.btn.btn-primary#saveFixedAssetBtn(type='submit') Save Asset
                      p.small.mt-2#fixedAssetStatus
                  .col-lg-8
                    h6.text-white Fixed Assets
                    .table-responsive
                      table.table.table-sm.table-hover#fixedAssetsTable
                        thead
                          tr
                            th Asset
                            th Printer
                            th Method
                            th.text-end Cost
                            th.text-end Accum. Dep.
                            th.text-end Action
                        tbody
                          if assets && assets.length
                            each a in assets
                              tr
                                td= a.name
                                td= a.printer ? a.printer.name : '-'
                                td= a.depreciationMethod
                                td.text-end GH₵ #{Number(a.purchaseCost || 0).toFixed(2)}
                                td.text-end GH₵ #{Number(a.accumulatedDepreciation || 0).toFixed(2)}
                                td.text-end
                                  if a.depreciationMethod === 'straight_line'
                                    span.badge.bg-info.text-dark Auto monthly
                                  else
                                    span.badge.bg-secondary Auto per usage
                          else
                            tr
                              td.text-muted(colspan='6') No fixed assets yet.

              #tabJournal.tab-pane.fade
                .d-flex.justify-content-between.align-items-center.mb-2
                  h6.text-white.mb-0 Recent Journal Entries
                  button.btn.btn-outline-info.btn-sm(type='button', data-bs-toggle='modal', data-bs-target='#journalHelpModal', aria-label='Journal help') Journal Help
                .table-responsive
                  table.table.table-sm.table-hover#journalEntriesTable
                    thead
                      tr
                        th Date
                        th Source
                        th Memo
                        th Lines
                    tbody
                      if entries && entries.length
                        each j in entries
                          tr
                            td #{j.date ? new Date(j.date).toLocaleString() : ''}
                            td= j.sourceType
                            td= j.memo
                            td
                              each line in j.lines
                                div.small #{line.accountCode} #{line.accountName}: Dr #{Number(line.debit || 0).toFixed(2)} / Cr #{Number(line.credit || 0).toFixed(2)}
                      else
                        tr
                          td.text-muted(colspan='4') No journal entries yet.

    .modal.fade#journalHelpModal(tabindex='-1', aria-hidden='true')
      .modal-dialog.modal-xl.modal-dialog-scrollable
        .modal-content.dark-surface
          .modal-header.border-secondary
            div
              h5.modal-title.text-white Journal & Account Types Help
              p.text-muted-light.small.mb-0 The journal explains every accounting event with debit and credit lines.
            button.btn-close.btn-close-white(type='button', data-bs-dismiss='modal', aria-label='Close')
          .modal-body.dark-card-body
            .alert.alert-info.py-2
              strong How to read it:
              span.ms-1 Assets and expenses usually increase with debits. Liabilities and revenue usually increase with credits.
            .row.g-3
              .col-lg-6
                .card.dark-surface.border-secondary.h-100
                  .card-body
                    h6.text-white Assets
                    p.text-muted-light.small Assets are things the business owns or expects to receive. They do not directly increase profit unless they later become revenue or expense.
                    .table-responsive
                      table.table.table-sm.mb-0
                        thead
                          tr
                            th Code
                            th Account
                            th What It Means
                            th P&L Effect
                        tbody
                          tr
                            td 1000
                            td Cash and Bank Books
                            td Money held in cash, bank, or MoMo books.
                            td No direct P&L effect; it changes when money comes in or goes out.
                          tr
                            td 1100
                            td Accounts Receivable
                            td Money customers owe after orders are placed.
                            td No direct P&L effect; revenue is recorded on the matching sales line.
                          tr
                            td 1200
                            td Inventory / Stock
                            td Stock bought but not yet consumed.
                            td P&L is hit when stock is used and moved to material cost.
                          tr
                            td 1300
                            td Prepaid Expenses
                            td Expenses paid now for future periods, such as rent paid in advance.
                            td P&L is hit only when released into expense.
                          tr
                            td 1500
                            td Fixed Assets
                            td Long-term assets such as printers.
                            td P&L is hit through depreciation, not full purchase cost at once.
                          tr
                            td 1590
                            td Accumulated Depreciation
                            td The total depreciation already charged against fixed assets.
                            td The depreciation expense line affects P&L.
              .col-lg-6
                .card.dark-surface.border-secondary.h-100
                  .card-body
                    h6.text-white Liabilities
                    p.text-muted-light.small Liabilities are amounts the business owes to suppliers, customers, or unpaid bills.
                    .table-responsive
                      table.table.table-sm.mb-0
                        thead
                          tr
                            th Code
                            th Account
                            th What It Means
                            th P&L Effect
                        tbody
                          tr
                            td 2000
                            td Supplier Payables
                            td Amount owed to suppliers, usually from credit purchases.
                            td No direct P&L effect; the related stock or expense creates the P&L effect.
                          tr
                            td 2100
                            td Accrued Payables
                            td Expenses recorded but not yet paid.
                            td P&L is hit when accrued; later payment only clears the liability.
                          tr
                            td 2200
                            td Customer Credits
                            td Money or credit balance the business owes to customers.
                            td No direct P&L effect when used; it clears receivables for orders.
              .col-lg-6
                .card.dark-surface.border-secondary.h-100
