extends ../layout

block content
  style.
    #accountingCapital .ledger-form-panel form,
    #accountingExpenseAdjustment .ledger-form-panel form,
    #accountingCashBooks .ledger-form-panel form {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: .75rem 1rem;
      align-items: end;
      padding: .95rem;
      border: 1px solid rgba(148, 163, 184, .22);
      border-radius: 1rem;
      background:
        linear-gradient(135deg, rgba(59, 130, 246, .08), rgba(15, 23, 42, .08)),
        rgba(255, 255, 255, .025);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .04);
    }
    #accountingCapital .ledger-form-panel form > .row,
    #accountingCapital .ledger-form-panel form > .card,
    #accountingCapital .ledger-form-panel form > p,
    #accountingExpenseAdjustment .ledger-form-panel form > .row,
    #accountingExpenseAdjustment .ledger-form-panel form > .card,
    #accountingExpenseAdjustment .ledger-form-panel form > p,
    #accountingCashBooks .ledger-form-panel form > .row,
    #accountingCashBooks .ledger-form-panel form > .card,
    #accountingCashBooks .ledger-form-panel form > p {
      grid-column: 1 / -1;
      margin-top: 0 !important;
      margin-bottom: 0 !important;
    }
    #accountingCapital .ledger-form-panel form > .mb-2,
    #accountingExpenseAdjustment .ledger-form-panel form > .mb-2,
    #accountingCashBooks .ledger-form-panel form > .mb-2 {
      margin-bottom: 0 !important;
    }
    #accountingCapital .ledger-form-panel form > button,
    #accountingExpenseAdjustment .ledger-form-panel form > button,
    #accountingCashBooks .ledger-form-panel form > button {
      justify-self: start;
      min-width: 150px;
    }
    #equityFixedAssetWrap .card-body,
    #manualExpenseAutoReleaseWrap .card-body {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: .65rem .9rem;
      align-items: end;
    }
    #equityFixedAssetWrap .card-body > h6,
    #equityFixedAssetWrap .card-body > p,
    #equityFixedAssetWrap .card-body > small,
    #manualExpenseAutoReleaseWrap .card-body > .form-check {
      grid-column: 1 / -1;
      margin-bottom: 0 !important;
    }
    #equityFixedAssetWrap .card-body > .row,
    #manualExpenseAutoReleaseWrap .card-body > .row {
      grid-column: 1 / -1;
    }
    #accountingCapital .ledger-entries-panel,
    #accountingExpenseAdjustment .ledger-entries-panel,
    #accountingCashBooks .ledger-entries-panel {
      position: relative;
      margin-top: .35rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(96, 165, 250, .45);
    }
    #accountingCapital .ledger-entries-panel::before,
    #accountingExpenseAdjustment .ledger-entries-panel::before,
    #accountingCashBooks .ledger-entries-panel::before {
      content: '';
      position: absolute;
      top: -2px;
      left: 0;
      width: 96px;
      height: 3px;
      border-radius: 999px;
      background: linear-gradient(90deg, #60a5fa, rgba(96, 165, 250, 0));
    }
    #accountingCapital .ledger-entries-panel > h6,
    #accountingExpenseAdjustment .ledger-entries-panel > h6,
    #accountingCashBooks .ledger-entries-panel > h6 {
      margin-bottom: .65rem;
    }
    .pl-range-separator {
      position: relative;
      margin: 1.25rem 0 1rem;
      border-top: 1px solid rgba(96, 165, 250, .45);
    }
    .pl-range-separator::before {
      content: '';
      position: absolute;
      top: -2px;
      left: 0;
      width: 120px;
      height: 3px;
      border-radius: 999px;
      background: linear-gradient(90deg, #60a5fa, rgba(96, 165, 250, 0));
    }
  .container
    .d-none(data-main-width='wide')
    .row
      .col-12
        .card.shadow-sm.dark-surface
          .card-body.dark-card-body#accountingPage
            .d-flex.justify-content-between.align-items-center.mb-3
              div
                h4.mb-0.text-white Ledger
                p.text-muted-light.small.mb-0 Accrual accounting for revenue, stock cost, fixed assets, and manual expenses.

            ul.nav.nav-tabs.mb-3(role='tablist')
              li.nav-item(role='presentation')
                button.nav-link.active(type='button', data-bs-toggle='tab', data-bs-target='#accountingFinancialStatement') Financial Statement
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#accountingCapital') Capital
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#accountingExpenseAdjustment') Expenses Adjustment
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#accountingFinancialControl') Financial Control
              li.nav-item(role='presentation')
                button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#accountingCashBooks') Cash Books

            .tab-content
              #accountingFinancialStatement.tab-pane.fade.show.active
                .d-flex.justify-content-between.align-items-center.mb-2
                  div
                    h5.text-white.mb-0 Financial Statement
                    p.text-muted-light.small.mb-0 Review business performance and position.
                ul.nav.nav-pills.mb-3(role='tablist')
                  li.nav-item(role='presentation')
                    button.nav-link.active(type='button', data-bs-toggle='tab', data-bs-target='#tabProfitLoss') Profit & Loss
                  li.nav-item(role='presentation')
                    button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#tabBalanceSheet') Balance Sheet
                .tab-content
                  #tabProfitLoss.tab-pane.fade.show.active
                    .d-flex.justify-content-between.align-items-center.mb-2
                      div
                        h6.text-white.mb-0 All-Time Profit & Loss
                        p.text-muted-light.small.mb-0 Lifetime records from the start of the ledger.
                    .row.g-2.mb-3
                      .col-6.col-lg-2
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Revenue
                            strong#plAllRevenue GH₵ 0.00
                      .col-6.col-lg-2
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Cost of Sales
                            strong#plAllCogs GH₵ 0.00
                      .col-6.col-lg-2
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Gross Profit
                            strong#plAllGross GH₵ 0.00
                      .col-6.col-lg-3
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Operating Expenses
                            strong#plAllOperating GH₵ 0.00
                      .col-6.col-lg-3
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Net Profit / Loss
                            strong#plAllNet GH₵ 0.00
                    .row.g-3
                      .col-lg-4
                        h6.text-white Revenue
                        table.table.table-sm#plAllRevenueTable
                          tbody
                            tr
                              td.text-muted Loading...
                      .col-lg-4
                        h6.text-white Cost of Sales
                        table.table.table-sm#plAllCogsTable
                          tbody
                            tr
                              td.text-muted Loading...
                      .col-lg-4
                        h6.text-white Operating Expenses
                        table.table.table-sm#plAllOperatingTable
                          tbody
                            tr
                              td.text-muted Loading...
                    .pl-range-separator
                    .d-flex.justify-content-between.align-items-center.mb-2
                      div
                        h6.text-white.mb-0 Date Range Profit & Loss
                        p.text-muted-light.small.mb-0 Use the filter below to load a specific month or custom period.
                    .d-flex.gap-2.align-items-end.mb-3
                      div
                        label.form-label.small.text-muted-light(for='accountingFrom') From
                        input.form-control.form-control-sm.form-control-dark#accountingFrom(type='date', value=defaultFrom)
                      div
                        label.form-label.small.text-muted-light(for='accountingTo') To
                        input.form-control.form-control-sm.form-control-dark#accountingTo(type='date', value=defaultTo)
                      button.btn.btn-primary.btn-sm#loadProfitLossBtn(type='button') Load P&L
                    .row.g-2.mb-3
                      .col-6.col-lg-2
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Revenue
                            strong#plRevenue GH₵ 0.00
                      .col-6.col-lg-2
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Cost of Sales
                            strong#plCogs GH₵ 0.00
                      .col-6.col-lg-2
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Gross Profit
                            strong#plGross GH₵ 0.00
                      .col-6.col-lg-3
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Operating Expenses
                            strong#plOperating GH₵ 0.00
                      .col-6.col-lg-3
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Net Profit / Loss
                            strong#plNet GH₵ 0.00
                    .row.g-3
                      .col-lg-4
                        h6.text-white Revenue
                        table.table.table-sm#plRevenueTable
                          tbody
                            tr
                              td.text-muted Loading...
                      .col-lg-4
                        h6.text-white Cost of Sales
                        table.table.table-sm#plCogsTable
                          tbody
                            tr
                              td.text-muted Loading...
                      .col-lg-4
                        h6.text-white Operating Expenses
                        table.table.table-sm#plOperatingTable
                          tbody
                            tr
                              td.text-muted Loading...

                  #tabBalanceSheet.tab-pane.fade
                    .d-flex.flex-wrap.gap-2.align-items-end.mb-3
                      div
                        label.form-label.small.text-muted-light(for='balanceSheetTo') As of
                        input.form-control.form-control-sm.form-control-dark#balanceSheetTo(type='date', value=defaultTo)
                      button.btn.btn-primary.btn-sm#loadBalanceSheetBtn(type='button') Load Balance Sheet
                      small.text-muted-light.ms-sm-2 Assets must equal liabilities plus equity. Equity includes capital, drawings, opening balances, and accumulated profit/loss.
                    .row.g-2.mb-3
                      .col-6.col-lg
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Total Assets
                            strong#balanceSheetAssets GH₵ 0.00
                      .col-6.col-lg
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Total Liabilities
                            strong#balanceSheetLiabilities GH₵ 0.00
                      .col-6.col-lg
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Business Value / Equity
                            strong#balanceSheetEquity GH₵ 0.00
                      .col-6.col-lg
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Liabilities + Equity
                            strong#balanceSheetLiabilitiesEquity GH₵ 0.00
                      .col-6.col-lg
                        .card.dark-surface.border-0
                          .card-body.p-2.dark-card-body
                            div.small.text-muted-light Status
                            span.badge#balanceSheetStatusBadge.bg-secondary Loading
                    .row.g-3
                      .col-lg-4
                        h6.text-white Assets
                        .table-responsive
                          table.table.table-sm.table-hover#balanceSheetAssetsTable
                            thead
                              tr
                                th Account
                                th Group
                                th.text-end Amount
                            tbody
                              tr
                                td.text-muted(colspan='3') Loading...
                      .col-lg-4
                        h6.text-white Liabilities
                        .table-responsive
                          table.table.table-sm.table-hover#balanceSheetLiabilitiesTable
                            thead
                              tr
                                th Account
                                th Group
                                th.text-end Amount
                            tbody
                              tr
                                td.text-muted(colspan='3') Loading...
                      .col-lg-4
                        h6.text-white Equity
                        .table-responsive
                          table.table.table-sm.table-hover#balanceSheetEquityTable
                            thead
                              tr
                                th Account
                                th Group
                                th.text-end Amount
                            tbody
                              tr
                                td.text-muted(colspan='3') Loading...


              #accountingCapital.tab-pane.fade
                .d-flex.justify-content-between.align-items-center.mb-2
                  div
                    h5.text-white.mb-0 Capital
                    p.text-muted-light.small.mb-0 Manage owner equity, opening balances, and fixed assets.
                ul.nav.nav-pills.mb-3(role='tablist')
                  li.nav-item(role='presentation')
                    button.nav-link.active(type='button', data-bs-toggle='tab', data-bs-target='#tabEquity') Equity
                  li.nav-item(role='presentation')
                    button.nav-link(type='button', data-bs-toggle='tab', data-bs-target='#tabFixedAssets') Fixed Assets
                .tab-content
                  #tabEquity.tab-pane.fade.show.active
                    .row.g-3.ledger-stacked-section
                      .col-lg-12.ledger-form-panel
                        h6.text-white Owner Equity & Opening Balances
                        p.small.text-muted-light.mb-2 Use this for owner investments, owner withdrawals, and existing asset/liability balances from before the accounting system started.
                        form#equityTransactionForm(data-disable-spinner='true')
                          .mb-2
                            label.form-label.text-muted-light(for='equityTransactionType') Entry type
                            select.form-select.form-select-dark#equityTransactionType(required)
                              option(value='owner_capital' selected) Owner capital / investment
                              option(value='owner_drawing') Owner drawing / withdrawal
                              option(value='opening_asset') Opening asset balance
                              option(value='opening_liability') Opening liability balance
                          .mb-2
                            label.form-label.text-muted-light(for='equityTransactionAccount') Affected account
                            select.form-select.form-select-dark#equityTransactionAccount(required)
                              each account in accounts
                                if ['asset', 'liability'].includes(account.type)
                                  option(value=account.code data-type=account.type data-group=account.group)= `${account.code} ${account.name}`
                          .row.g-2
                            .col-6
                              label.form-label.text-muted-light(for='equityTransactionAmount') Amount
                              input.form-control.form-control-dark#equityTransactionAmount(type='number', min='0.01', step='0.01', required)
                            .col-6
                              label.form-label.text-muted-light(for='equityTransactionDate') Date
                              input.form-control.form-control-dark#equityTransactionDate(type='date', value=defaultTo)
                          .mb-2.mt-2
                            label.form-label.text-muted-light(for='equityTransactionDescription') Description
                            input.form-control.form-control-dark#equityTransactionDescription(type='text', placeholder='e.g. Opening cash balance')
                          .card.dark-surface.border-secondary.mb-2.d-none#equityFixedAssetWrap
                            .card-body.p-2
                              h6.text-white.mb-1 Opening Fixed Asset Details
                              p.small.text-muted-light.mb-2 The Amount above becomes the opening book value/cost. Depreciation starts from the selected date.
                              .mb-2
                                label.form-label.text-muted-light(for='equityFixedAssetName') Asset name
                                input.form-control.form-control-dark#equityFixedAssetName(type='text', placeholder='e.g. Large format printer')
                              .mb-2
                                label.form-label.text-muted-light(for='equityFixedAssetPrinter') Linked printer
                                select.form-select.form-select-dark#equityFixedAssetPrinter
                                  option(value='') Not linked
                                  each p in printers
                                    option(value=p._id)= p.name
                                small.text-muted-light Link only actual printer assets. Tables, chairs, and other assets stay unlinked.
                              .row.g-2.mt-1
                                .col-6
                                  label.form-label.text-muted-light(for='equityFixedAssetResidual') Residual value
                                  input.form-control.form-control-dark#equityFixedAssetResidual(type='number', min='0', step='0.01', value='0')
                                .col-6
                                  label.form-label.text-muted-light(for='equityFixedAssetMethod') Depreciation
                                  select.form-select.form-select-dark#equityFixedAssetMethod
                                    option(value='straight_line' selected) Straight line
                                    option(value='usage') Usage based
                              .row.g-2.mt-1
                                .col-6#equityFixedAssetUnitsWrap
                                  label.form-label.text-muted-light(for='equityFixedAssetUnits') Useful life units
                                  input.form-control.form-control-dark#equityFixedAssetUnits(type='number', min='0', step='1', placeholder='e.g. 1000000')
                                .col-6#equityFixedAssetMonthsWrap
                                  label.form-label.text-muted-light(for='equityFixedAssetMonths') Useful life months
                                  input.form-control.form-control-dark#equityFixedAssetMonths(type='number', min='0', step='1', placeholder='e.g. 60')
                          .mb-2#equityCashBookWrap
                            label.form-label.text-muted-light(for='equityCashBook') Cash book affected
                            select.form-select.form-select-dark#equityCashBook
                              option(value='') Select cash book
                              each book in cashBooks
                                option(value=book._id data-kind=book.kind)= `${book.name} (${book.kind === 'momo' ? 'MoMo' : (book.kind === 'bank' ? 'Bank' : 'Cash')})`
                          .row.g-2.d-none#equityMomoWrap
                            .col-6
                              label.form-label.text-muted-light(for='equityMomoNumber') MoMo number
                              input.form-control.form-control-dark#equityMomoNumber(type='text')
                            .col-6
                              label.form-label.text-muted-light(for='equityMomoTxId') Transaction ID
                              input.form-control.form-control-dark#equityMomoTxId(type='text')
                          .row.g-2.d-none#equityBankWrap
                            .col-6
                              label.form-label.text-muted-light(for='equityChequeNumber') Cheque number
                              input.form-control.form-control-dark#equityChequeNumber(type='text')
                            .col-6
                              label.form-label.text-muted-light(for='equityDepositDetails') Deposit details
                              input.form-control.form-control-dark#equityDepositDetails(type='text')
                          button.btn.btn-primary#saveEquityTransactionBtn(type='submit') Save Equity Entry
                          p.small.mt-2#equityTransactionStatus
                      .col-lg-12.ledger-entries-panel
                        h6.text-white Recent Equity Entries
                        .table-responsive
                          table.table.table-sm.table-hover#equityTransactionsTable
                            thead
                              tr
                                th Date
                                th Type
                                th Account
                                th Description
                                th Cash Book
                                th.text-end Amount
                            tbody
                              if equityTransactions && equityTransactions.length
                                each entry in equityTransactions
                                  tr
                                    td #{entry.date ? new Date(entry.date).toLocaleDateString() : ''}
                                    td= entry.type
                                    td #{entry.accountCode} #{entry.accountName}
                                    td
                                      div= entry.description
                                      if entry.fixedAssetName
                                        small.text-muted-light Asset: #{entry.fixedAssetName}
                                    td= entry.cashBookName
                                    td.text-end GH₵ #{Number(entry.amount || 0).toFixed(2)}
                              else
                                tr
                                  td.text-muted(colspan='6') No equity entries yet.

                  #tabFixedAssets.tab-pane.fade
                    .row.g-3.ledger-stacked-section
                      .col-lg-12.ledger-form-panel
                        h6.text-white Create Fixed Asset
                        form#fixedAssetForm(data-disable-spinner='true')
                          .mb-2
                            label.form-label.text-muted-light(for='fixedAssetName') Name
                            input.form-control.form-control-dark#fixedAssetName(type='text', placeholder='e.g. Canon Printer', required)
                          .mb-2
                            label.form-label.text-muted-light(for='fixedAssetPrinter') Linked printer
                            select.form-select.form-select-dark#fixedAssetPrinter
                              option(value='') Not linked
                              each p in printers
                                option(value=p._id)= p.name
                          .row.g-2
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetCost') Purchase cost
                              input.form-control.form-control-dark#fixedAssetCost(type='number', min='0.01', step='0.01', required)
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetResidual') Residual value
                              input.form-control.form-control-dark#fixedAssetResidual(type='number', min='0', step='0.01', value='0')
                          .row.g-2.mt-1
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetMethod') Depreciation
                              select.form-select.form-select-dark#fixedAssetMethod
                                option(value='usage' selected) Usage based
                                option(value='straight_line') Straight line
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetDate') Purchase date
                              input.form-control.form-control-dark#fixedAssetDate(type='date', value=defaultTo)
                          .row.g-2.mt-1
                            .col-6#fixedAssetUnitsWrap
                              label.form-label.text-muted-light(for='fixedAssetUnits') Useful life units
                              input.form-control.form-control-dark#fixedAssetUnits(type='number', min='0', step='1', placeholder='e.g. 1000000')
                            .col-6#fixedAssetMonthsWrap
                              label.form-label.text-muted-light(for='fixedAssetMonths') Useful life months
                              input.form-control.form-control-dark#fixedAssetMonths(type='number', min='0', step='1')
                          p.small.text-muted-light.mt-2.mb-0 Usage based posts when the linked printer is used. Straight line posts automatically once per month.
                          .mb-2.mt-2
                            label.form-label.text-muted-light(for='fixedAssetCashBook') Cash book used
                            select.form-select.form-select-dark#fixedAssetCashBook
                              option(value='') Bought on credit / unpaid
                              each book in cashBooks
                                option(value=book._id data-kind=book.kind)= `${book.name} (${book.kind === 'momo' ? 'MoMo' : (book.kind === 'bank' ? 'Bank' : 'Cash')})`
                          .row.g-2.d-none#fixedAssetMomoWrap
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetMomoNumber') MoMo number
                              input.form-control.form-control-dark#fixedAssetMomoNumber(type='text')
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetMomoTxId') Transaction ID
                              input.form-control.form-control-dark#fixedAssetMomoTxId(type='text')
                          .row.g-2.d-none#fixedAssetBankWrap
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetChequeNumber') Cheque number
                              input.form-control.form-control-dark#fixedAssetChequeNumber(type='text')
                            .col-6
                              label.form-label.text-muted-light(for='fixedAssetDepositDetails') Deposit details
                              input.form-control.form-control-dark#fixedAssetDepositDetails(type='text')
                          .mb-2
                            label.form-label.text-muted-light(for='fixedAssetNote') Note
                            input.form-control.form-control-dark#fixedAssetNote(type='text')
                          button.btn.btn-primary#saveFixedAssetBtn(type='submit') Save Asset
                          p.small.mt-2#fixedAssetStatus
                      .col-lg-12.ledger-entries-panel
                        h6.text-white Fixed Assets
                        .table-responsive
                          table.table.table-sm.table-hover#fixedAssetsTable
                            thead
                              tr
                                th Asset
                                th Printer
                                th Method
                                th.text-end Cost
                                th.text-end Accum. Dep.
                                th.text-end Action
                            tbody
                              if assets && assets.length
                                each a in assets
                                  tr
                                    td
                                      span= a.name
                                      if a.code
                                        span.badge.bg-info.text-dark.ms-2= a.code
                                    td= a.printer ? a.printer.name : '-'
                                    td= a.depreciationMethod
                                    td.text-end GH₵ #{Number(a.purchaseCost || 0).toFixed(2)}
