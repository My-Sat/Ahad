                            td 5000
                            td Material Cost of Sales
                            td Cost of stock/materials consumed by jobs.
                            td Reduces gross profit.
                          tr
                            td 5100
                            td Out-sourced Cost of Sales
                            td Cost payable to artists/partners handling outsourced jobs.
                            td Reduces gross profit.
                          tr
                            td 5200
                            td Printer Depreciation
                            td Usage or monthly depreciation charged for production printers.
                            td Reduces gross profit when tied to production.
                          tr
                            td 6000
                            td Rent Expense
                            td Rent cost released or recorded for the period.
                            td Reduces net profit.
                          tr
                            td 6100
                            td Staff Expense
                            td Salary or staff-related cost.
                            td Reduces net profit.
                          tr
                            td 6200
                            td Utilities / Electricity Expense
                            td Electricity, water, and related utility costs.
                            td Reduces net profit.
                          tr
                            td 6300
                            td Internet / Data Expense
                            td Internet and data cost.
                            td Reduces net profit.
                          tr
                            td 6400
                            td Fixed Asset Depreciation
                            td Straight-line depreciation for non-printer assets such as tables, chairs, computers, or fixtures.
                            td Reduces net profit as an operating expense.
                          tr
                            td 6900
                            td General Expense
                            td Other business expenses.
                            td Reduces net profit.
