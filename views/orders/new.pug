extends ../layout

block content
  .container#ordersNewPage(data-is-admin=(currentUser && currentUser.role && String(currentUser.role).toLowerCase() === 'admin') ? 'true' : 'false')
    .d-none(data-main-width='wide')
    .row.justify-content-center
      .col-12.col-md-12
        .card.shadow-sm.dark-surface
          .card-body.dark-card-body
            // Title row: Job Order + Orders explorer button
            .d-flex.justify-content-between.align-items-center.mb-3
              h4.mb-0.text-white Job Order
              // Orders button (existing)
              .mb-2
                button.btn.btn-outline-light-custom.btn-sm#openOrdersExplorerBtn(type='button', title='View orders')
                  i.bi.bi-list-check.me-1
                  | Orders

            input(type='hidden', id='orderCustomerId', value=(customer && customer._id ? customer._id : ''))
            input(type='hidden', id='orderSubmissionId', value='')
            input(type='hidden', id='orderInvoiceId', value='')

            // Selected customer at top (centered)
            - const hasCustomer = !!customer;
            .card.mb-3.dark-surface#selectedCustomerCard(style='border:1px solid rgba(255,255,255,.08);' + (hasCustomer ? '' : 'display:none;'))
              .card-body.dark-card-body.py-2.text-center
                div.small.text-muted-light.mb-1 Selected customer
                if customer && (customer.category === 'artist' || customer.category === 'organisation')
                  strong#selectedCustomerName(style='color:#21BCFF;') #{customer.businessName || customer.phone}
                else if customer
                  strong#selectedCustomerName(style='color:#21BCFF;') #{customer.firstName || customer.businessName || customer.phone}
                else
                  strong#selectedCustomerName(style='color:#21BCFF;')

                // phone
                if customer
                  strong#selectedCustomerPhone.text-muted-light.ms-3 #{customer.phone}
                else
                  strong#selectedCustomerPhone.text-muted-light.ms-3

                // customer type (same visual weight)
                -
                  const categoryLabel =
                    (customer && customer.category === 'artist')
                      ? 'Artist'
                      : (customer && customer.category === 'organisation')
                        ? 'Organisation'
                        : (customer && customer.category === 'regular')
                          ? 'Regular'
                          : 'One-Time';
                if customer
                  strong#selectedCustomerCategory.text-muted-light.ms-3 #{categoryLabel}
                else
                  strong#selectedCustomerCategory.text-muted-light.ms-3
            .card.mb-3.dark-surface#submittedCustomersCard(style='border:1px solid rgba(255,255,255,.08);')
              .card-body.dark-card-body.py-2
                .d-flex.justify-content-between.align-items-center.mb-2
                  h6.mb-0.text-white Submitted Customers
                  button.btn.btn-sm.btn-outline-light-custom#reloadSubmittedCustomersBtn(type='button') Reload

                .row.g-2
                  .col-12.col-md-8
                    select.form-select.form-select-dark#submittedCustomerSelect
                      option(value='') -- Select submitted customer/walk-in --
                  .col-12.col-md-4
                    small.text-muted-light#submittedCustomersHint Select a submitted customer to load assigned categories.

            .card.mb-3.dark-surface(style='border:1px solid rgba(255,255,255,.08);')
              .card-body.dark-card-body.py-2
                label.form-label.mb-1(for='orderJobNote') Order Note (optional)
                input.form-control.form-control-dark#orderJobNote(
                  type='text',
                  maxlength='140',
                  placeholder='e.g. add a note or job type'
                )

            // selection row (service category + services + books)
            .row.g-2.mb-3
              .col-md-4
                label.form-label(for='serviceCategorySelect') Service Category
                select.form-select.form-select-dark(id='serviceCategorySelect', aria-label='Service Category')
                  // placeholder — selected but disabled so user must explicitly choose a category
                  option(value='') -- Select a submitted customer first --
              .col-md-4
                label.form-label(for='serviceSelect') Service
                select.form-select.form-select-dark(id='serviceSelect')
                  option(value='') -- Select a service --
                  each s in services
                    // keep server-provided services for backward compatibility; prices will be loaded client-side
                    option(value=s._id)= s.name
              .col-md-3.d-flex.align-items-end

            // price rules list (populated via AJAX or when a book is selected)
            .card.mt-3.dark-surface
              .card-body.dark-card-body
                h6.mb-2.text-white Price rules for selected service / book
                p.text-muted-light.small Select a rule and enter number of pages/qty (if applicable) then click Apply to add to cart.
                #pricesList
                  p.text-muted-light Select a service to load price rules.

          // Cart / Order summary
          .card.mt-3.dark-surface
            .card-body.dark-card-body
              .d-flex.justify-content-between.align-items-center.mb-2
                h6.mb-0.text-white Cart

                // ADMIN-ONLY: Manual discount (per order, not saved)
                if currentUser && currentUser.role && String(currentUser.role).toLowerCase() === 'admin'
                  span.badge.bg-info Manual adjustment

              // ADMIN-ONLY: manual discount UI (applies AFTER items are in cart)
              // NOTE: This block now contains ONLY the inputs/buttons.
              // The discount breakdown (#manualDiscountSummary) is rendered under Cart totals instead.
              if currentUser && currentUser.role && String(currentUser.role).toLowerCase() === 'admin'
                .card.mb-3.dark-surface(style='border:1px solid rgba(33,188,255,.22);box-shadow:0 12px 30px rgba(0,0,0,.10);')
                  .card-header.bg-transparent.border-0.p-2
                    button.btn.btn-sm.btn-outline-light-custom.w-100.d-flex.align-items-center.justify-content-between(type='button', data-bs-toggle='collapse', data-bs-target='#manualAdjustmentCollapse', aria-expanded='false', aria-controls='manualAdjustmentCollapse')
                      span.d-flex.align-items-center.gap-2
                        i.bi.bi-sliders
                        span.fw-semibold Adjustments
                        span.badge.rounded-pill.bg-info.text-dark Optional
                      span.small.text-muted-light Discount / Premium
                  .collapse#manualAdjustmentCollapse
                    .card-body.dark-card-body.pt-0
                      .rounded-3.p-3(style='background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.08);')
                        .row.g-2.align-items-end
                          .col-12.col-md-3
                            label.form-label.mb-1(for='manualAdjustmentType') Adjustment
                            select.form-select.form-select-sm.form-select-dark#manualAdjustmentType
                              option(value='discount' selected) Discount
                              option(value='premium') Premium
                          .col-12.col-md-3
                            label.form-label.mb-1(for='manualDiscountMode') Mode
                            select.form-select.form-select-sm.form-select-dark#manualDiscountMode
                              option(value='amount') Amount (GH₵)
                              option(value='percent') Percent (%)
                          .col-12.col-md-3
                            label.form-label.mb-1(for='manualDiscountValue') Value
                            input.form-control.form-control-sm.form-control-dark#manualDiscountValue(type='number', min='0', step='0.01', placeholder='e.g. 5 or 10')
                          .col-12.col-md-3.d-flex.gap-2.justify-content-end
                            button.btn.btn-sm.btn-outline-light-custom#applyManualDiscountBtn(type='button') Apply Discount
                            button.btn.btn-sm.btn-outline-light-custom#clearManualDiscountBtn(type='button', style='display:none;') Clear

                        p.text-muted-light.small.mt-2.mb-0
                          | This adjustment applies only to this order and will not be saved. You must re-apply it for each order when needed.

              if currentUser && currentUser.role && String(currentUser.role).toLowerCase() === 'admin'
                .card.mb-3.dark-surface(style='border:1px solid rgba(255,255,255,.12);box-shadow:0 12px 30px rgba(0,0,0,.10);')
                  .card-header.bg-transparent.border-0.p-2
                    button.btn.btn-sm.btn-outline-light-custom.w-100.d-flex.align-items-center.justify-content-between(type='button', data-bs-toggle='collapse', data-bs-target='#cartVatCollapse', aria-expanded='false', aria-controls='cartVatCollapse')
                      span.d-flex.align-items-center.gap-2
                        i.bi.bi-percent
                        span.fw-semibold VAT
                        span.badge.rounded-pill.bg-secondary Optional
                      span.small.text-muted-light Apply after adjustment
                  .collapse#cartVatCollapse
                    .card-body.dark-card-body.pt-0
                      .rounded-3.p-3(style='background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.08);')
                        .row.g-2.align-items-end
                          .col-12.col-md-3
                            label.form-label.mb-1(for='cartTaxMode') VAT Mode
                            select.form-select.form-select-sm.form-select-dark#cartTaxMode
                              option(value='amount') Amount (GH₵)
                              option(value='percent') Percent (%)
                          .col-12.col-md-3
                            label.form-label.mb-1(for='cartTaxValue') VAT Value
                            input.form-control.form-control-sm.form-control-dark#cartTaxValue(type='number', min='0', step='0.01', placeholder='e.g. 5 or 10')
                          .col-12.col-md-6.d-flex.gap-2.justify-content-end
                            button.btn.btn-sm.btn-outline-light-custom#applyCartTaxBtn(type='button') Apply VAT
                            button.btn.btn-sm.btn-outline-light-custom#clearCartTaxBtn(type='button', style='display:none;') Clear VAT
                        p.text-muted-light.small.mt-2.mb-0 VAT is applied after adjustment/discount/premium, if any.

              .table-responsive
                table.table.table-sm.table-borderless#cartTable
                  thead
                    tr
                      th Selection
                      th.text-center Pages
                      th.text-center QTY
                      th.text-center Sheets
                      th.text-end Unit
                      th.text-end Subtotal
                      th.text-center Actions
                  tbody#cartTbody
                    tr
                      td.text-muted-light(colspan='7') Cart is empty.


                // ✅ ADMIN-ONLY: discount breakdown rendered under cart totals (only shown when discount is applied)
                if currentUser && currentUser.role && String(currentUser.role).toLowerCase() === 'admin'
                  .mt-2#manualDiscountSummary(style='display:none;')
                    .d-flex.justify-content-end
                      .text-end
                        div.small.text-muted-light Total before discount:
                        strong#manualDiscountTotalBefore.text-white GH₵ 0.00
                    .d-flex.justify-content-end
                      .text-end
                        div.small.text-muted-light#manualDiscountAmountLabel Discount:
                        strong#manualDiscountAmount.text-white - GH₵ 0.00
                if currentUser && currentUser.role && String(currentUser.role).toLowerCase() === 'admin'
                  .mt-2#cartTaxSummary(style='display:none;')
                    .d-flex.justify-content-end
                      .text-end
                        div.small.text-muted-light VATable amount:
                        strong#cartTaxableAmount.text-white GH₵ 0.00
                    .d-flex.justify-content-end
                      .text-end
                        div.small.text-muted-light VAT:
                        strong#cartTaxAmount.text-white + GH₵ 0.00
                .d-flex.justify-content-end.mt-2
                  .text-end.me-3#outsourcedCartWrap(style='display:none;')
                    div.small.text-muted-light Out-Sourced Cost Total:
                    strong#outsourcedCartTotal.text-info GH₵ 0.00
                  span.me-3.fs-5.text-white Total:
                  strong.fs-5#cartTotal.text-white GH₵ 0.00


                .d-flex.justify-content-end.mt-3.gap-2
                  .dropdown.cart-invoice-actions
                    button.btn.btn-outline-light-custom.dropdown-toggle#cartInvoiceActionsBtn(type='button', aria-expanded='false')
                      i.bi.bi-receipt.me-1
                      | Invoices
                    ul.dropdown-menu.dropdown-menu-dark.dropdown-menu-end
                      li
                        button.dropdown-item#saveCartInvoiceBtn(type='button', disabled)
                          i.bi.bi-save.me-1
                          | Save Invoice
                      li
                        button.dropdown-item#printCartInvoiceBtn(type='button', disabled)
                          i.bi.bi-printer.me-1
                          | Print Invoice
                      li
                        button.dropdown-item#shareCartInvoiceBtn(type='button', disabled)
                          i.bi.bi-share.me-1
                          | Send / Share PDF
                      li
                        hr.dropdown-divider
                      li
                        button.dropdown-item#openCartInvoicesModalBtn(type='button')
                          i.bi.bi-search.me-1
                          | Saved Invoices
                  button.btn.btn-outline-light-custom#saveDraftBtn(type='button', disabled) Save Draft
                  button.btn.btn-primary#orderNowBtn(type='button', disabled) Order Now

    // small debug area
    .mt-3.text-muted-light.small
      | After placing the order you will receive an Order ID to use at payment.

  // Orders Explorer Modal (rich UI, date filters, table) - unchanged...
  .modal.fade(id='ordersExplorerModal', tabindex='-1', aria-labelledby='ordersExplorerModalLabel', aria-hidden='true')
    .modal-dialog.modal-xl.modal-dialog-centered
      .modal-content.dark-surface
        .modal-header
          h5.modal-title(id='ordersExplorerModalLabel') Orders Explorer
          button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
        .modal-body.dark-card-body
          .row.g-2.mb-3.align-items-center
            .col-auto
              label.form-label.mb-0
                small.text-muted-light Date Range
            .col-auto
              input.form-control.form-control-dark(type='date', id='ordersFrom')
            .col-auto
              input.form-control.form-control-dark(type='date', id='ordersTo')
            .col-auto.d-flex.align-items-center.flex-nowrap
              .btn-group.flex-shrink-0
                button.btn.btn-outline-light-custom.btn-sm#presetToday(type='button') Today
                button.btn.btn-outline-light-custom.btn-sm#presetYesterday(type='button') Yesterday
                button.btn.btn-outline-light-custom.btn-sm#presetThisWeek(type='button') This Week
              button.btn.btn-primary.btn-sm.ms-2.flex-shrink-0#fetchOrdersBtn(type='button') Refresh
              button.btn.btn-outline-info.btn-sm.ms-2.flex-shrink-0#toggleOutsourcedOrdersBtn(type='button', style='width: 106px; white-space: nowrap;') Outsourced
            .col-auto#outsourcedArtistBalanceFilterWrap(style='display:none;')
              select.form-select.form-select-sm.form-select-dark#outsourcedArtistBalanceFilter
                option(value='all') All Artists
                option(value='credit') With Credit Balance
                option(value='no_credit') Without Credit Balance
            .col-auto.text-end
              small.text-muted-light#ordersCount -- results

          // search / table
          .table-responsive
            table.table.table-hover.table-sm#ordersTable
              thead
                tr
                  th Name
                  th Note / Job Type
                  th.text-end Total
                  th Status
                  th Created
                  th.text-center Actions
              tbody
                tr
                  td.text-muted-light(colspan='6') Use the date filters above and click Refresh to load orders.

        .modal-footer
          button.btn.btn-secondary(type='button', data-bs-dismiss='modal') Close

  .modal.fade(id='orderDetailsModal', tabindex='-1', aria-labelledby='orderDetailsModalLabel', aria-hidden='true')
    .modal-dialog.modal-lg.modal-dialog-centered
      .modal-content.dark-surface
        .modal-header
          h5.modal-title#orderDetailsModalLabel Order Details
          button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
        .modal-body.dark-card-body
          .small.text-muted-light.mb-3#orderDetailsMeta
          #orderDetailsJson
        .modal-footer
          button.btn.btn-outline-light-custom.btn-sm#copyDetailOrderIdBtn(type='button') Copy ID
          button.btn.btn-outline-light-custom.btn-sm#printDetailOrderBtn(type='button') Print
          button.btn.btn-secondary(type='button', data-bs-dismiss='modal') Close

  .modal.fade(id='cartInvoicesModal', tabindex='-1', aria-labelledby='cartInvoicesModalLabel', aria-hidden='true')
    .modal-dialog.modal-lg.modal-dialog-centered
      .modal-content.dark-surface
        .modal-header
          h5.modal-title#cartInvoicesModalLabel Saved Invoices
          button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
        .modal-body.dark-card-body
          .d-flex.justify-content-between.align-items-center.mb-2
            p.text-muted-light.mb-0 Search by customer name, phone, or invoice number.
            button.btn.btn-sm.btn-outline-light-custom#reloadCartInvoicesBtn(type='button') Reload
          input.form-control.form-control-dark.mb-3#cartInvoiceSearchInput(type='search', placeholder='Search invoice by name, phone or invoice no')
          .list-group#cartInvoicesList
            .list-group-item.dark-surface.text-muted-light No saved invoices loaded.
        .modal-footer
          button.btn.btn-secondary(type='button', data-bs-dismiss='modal') Close
  // Keep Orders New scripts inside #main-content so dashboard_nav AJAX loads them
  script(defer src='/javascripts/customer_editor.js')


