extends ../layout

block content
  .container
    .d-none(data-main-width='wide')
    .row
      .col-12
        .card.shadow-sm.dark-surface
          .card-body.dark-card-body
            .d-flex.justify-content-between.align-items-center.mb-3
              h4.mb-0.text-white Order Details
              .btn-group
                a.btn.btn-outline-secondary.btn-sm(href='/orders/new')
                  | Back to Orders

            // Order meta
            .mb-3
              if handler
                p.mb-1
                  strong Handled by:
                  |  #{handler.name || handler.username || handler._id}

              if customer
                - var custLabel = ''
                - if (customer.category === 'artist') { custLabel = customer.businessName || customer.phone || ''; }
                - else { custLabel = customer.firstName || customer.businessName || customer.phone || ''; }
                p.mb-1
                  strong Customer:
                  |  #{custLabel}

              p.mb-1
                strong Order ID:
                |  #{order.orderId}
              if order.jobNote
                p.mb-1
                  strong Note / Job Type:
                  |  #{order.jobNote}

              p.mb-1
                strong Status:
                |  #{order.status}

              p.mb-1
                strong Created:
                - var createdStr = ''
                - try { createdStr = order.createdAt ? new Date(order.createdAt).toLocaleString() : ''; } catch (e) { createdStr = ''; }
                |  #{createdStr}

            // Items
            h6.mb-2.text-white Items
            - var orderItemGroups = []
            - var orderItemGroupMap = {}
            - var currencySymbol = 'GH' + String.fromCharCode(0x20B5)
            - if (order.items && order.items.length) {
            -   for (var oi = 0; oi < order.items.length; oi++) {
            -     var it = order.items[oi] || {}
            -     var rawLabel = it.selectionLabel || ''
            -     var isLargeFormat = String(it.pricingMode || '').toLowerCase() === 'large_format'
            -     var subs = '(no label)'
            -     if (isLargeFormat && rawLabel) {
            -       subs = rawLabel
            -     } else if (rawLabel && rawLabel.length) {
            -       var parts = String(rawLabel).split(' + ')
            -       var out = []
            -       for (var pi = 0; pi < parts.length; pi++) {
            -         var part = parts[pi]
            -         var idx = part.indexOf(':')
            -         var s = (idx >= 0) ? part.slice(idx + 1) : part
            -         s = String(s || '').trim()
            -         if (s) out.push(s)
            -       }
            -       if (out.length) subs = out.join(', ')
            -     }
            -     var rawPages = Number(it.pages || 1)
            -     var qty = (typeof it.effectiveQty !== 'undefined' && it.effectiveQty !== null) ? Number(it.effectiveQty) : (it.fb ? Math.ceil(rawPages / 2) : rawPages)
            -     var factor = Number(it.factor || 1)
            -     if (isNaN(factor) || factor < 1) factor = 1
            -     var usesFactorPricing = !!(it.printer || Number(it.outsourcedTotal || 0) > 0 || factor > 1)
            -     var sheets = usesFactorPricing ? (qty * factor) : qty
            -     if (isNaN(sheets) || sheets < 0) sheets = 0
            -     var qtyLabel = usesFactorPricing ? 'Sheets' : 'QTY'
            -     var largeSize = ''
            -     var largeQty = 0
            -     var largeSqft = 0
            -     if (isLargeFormat) {
            -       largeQty = Math.max(1, Math.floor(Number(it.largeFormatQty || it.factor || 1)))
            -       largeSqft = Number(it.largeFormatSquareFeet || it.effectiveQty || 0)
            -       largeSize = Number(it.largeFormatLength || 0) + ' x ' + Number(it.largeFormatBreadth || 0) + ' ' + (it.largeFormatUnit || 'feet')
            -       qtyLabel = 'QTY'
            -       sheets = largeQty
            -     }
            -     var subtotal = Number(it.subtotal || 0)
            -     var serviceTitle = String(it.serviceName || 'Service').trim() || 'Service'
            -     var serviceKey = serviceTitle.toLowerCase()
            -     if (!orderItemGroupMap[serviceKey]) {
            -       orderItemGroupMap[serviceKey] = { title: serviceTitle, items: [], subtotal: 0 }
            -       orderItemGroups.push(orderItemGroupMap[serviceKey])
            -     }
            -     orderItemGroupMap[serviceKey].items.push({ item: it, label: subs, qtyLabel: qtyLabel, sheets: sheets, rawPages: rawPages, factor: factor, usesFactorPricing: usesFactorPricing, subtotal: subtotal, isLargeFormat: isLargeFormat, largeSize: largeSize, largeSqft: largeSqft })
            -     orderItemGroupMap[serviceKey].subtotal += subtotal
            -   }
            -   for (var gi = 0; gi < orderItemGroups.length; gi++) {
            -     orderItemGroups[gi].subtotal = Number(orderItemGroups[gi].subtotal || 0)
            -   }
            - }
            if orderItemGroups.length
              .list-group.mb-3
                each group in orderItemGroups
                  .list-group-item(style='background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);padding:0.55rem 0.75rem;')
                    strong.text-white #{group.title}
                  each row in group.items
                    - var it = row.item || {}
                    .list-group-item.d-flex.justify-content-between.align-items-center
                      .me-2(style='min-width:0;flex:1;')
                        div(style='white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:480px;')
                          span.text-white #{row.label}
                        if it.spoiled
                          span.text-danger.ms-2 Spoiled: #{it.spoiled}
                      .text-end(style='min-width:200px;')
                        div #{row.qtyLabel}: #{row.sheets}
                        if row.isLargeFormat
                          div Size: #{row.largeSize}
                          div Sq ft: #{Number(row.largeSqft || 0).toFixed(2)}
                        else if row.usesFactorPricing
                          div Pages: #{row.rawPages}
                        if !row.isLargeFormat && row.usesFactorPricing && row.factor > 1
                          div QTY x#{row.factor}
                        div Unit: #{currencySymbol} #{Number(it.unitPrice || 0).toFixed(2)}
                        div Subtotal: #{currencySymbol} #{Number(row.subtotal || 0).toFixed(2)}
                        if it.printerName
                          div.small.text-muted-light Printer: #{it.printerName}
                  .list-group-item.d-flex.justify-content-end(style='background:rgba(255,255,255,.04);border-bottom:2px solid rgba(255,255,255,.16);padding:0.45rem 0.75rem;')
                    strong.text-white #{group.title} subtotal: #{currencySymbol} #{Number(group.subtotal || 0).toFixed(2)}
            else
              p.text-muted-light No items listed.

            // Totals + payments summary (DISCOUNT INCLUDED)
            - var hasAdjustment = Math.abs(Number(order.discountAmount || 0)) > 0
            - var isPremiumAdj = Number(order.discountAmount || 0) < 0
            - var totalBeforeDiscount = 0
            - if (typeof order.totalBeforeDiscount !== 'undefined' && order.totalBeforeDiscount !== null) {
            -   totalBeforeDiscount = Number(order.totalBeforeDiscount || 0)
            - } else {
            -   totalBeforeDiscount = Number((Number(order.total || 0) + Number(order.discountAmount || 0)).toFixed(2))
            - }
            - var db = (order.discountBreakdown && typeof order.discountBreakdown === 'object') ? order.discountBreakdown : {}
            - var scope = String(db.scope || '').trim()
            - var discountApplied = ''
            - if (hasAdjustment) {
            -   if (db.appliedLabel) discountApplied = String(db.appliedLabel)
            -   else if (db.appliedName) discountApplied = String(db.appliedName)
            -   else if (scope === 'customer_type') {
            -     var raw = db.customerType || db.target || (Array.isArray(db.targets) ? db.targets[0] : '') || db.key || db.label || ''
            -     var key = String(raw || '').toLowerCase().trim()
            -     if (key === 'regular') discountApplied = 'Regular'
            -     else if (key === 'one_time') discountApplied = 'One-Time'
            -     else if (key === 'organisation') discountApplied = 'Organisation'
            -     else if (key === 'artist') discountApplied = 'Artist'
            -     else {
            -       var parts2 = String(raw || '').split('_')
            -       var tmp = []
            -       for (var j = 0; j < parts2.length; j++) {
            -         var p2 = parts2[j]
            -         if (p2 && p2.length) tmp.push(p2.charAt(0).toUpperCase() + p2.slice(1))
            -       }
            -       discountApplied = tmp.join(' ')
            -     }
            -   } else if (scope === 'service') {
            -     discountApplied = String(db.serviceName || db.targetName || db.name || db.label || '').trim()
            -   } else if (scope === 'service_category') {
            -     discountApplied = String(db.categoryName || db.targetName || db.name || db.label || '').trim()
            -   } else {
            -     discountApplied = String(db.label || 'Discount').trim()
            -   }
            - }

            - var taxAmount = Number(order.taxAmount || 0)
            - var hasTax = taxAmount > 0
            - var tb = (order.taxBreakdown && typeof order.taxBreakdown === 'object') ? order.taxBreakdown : {}
            - var taxableAmount = (typeof tb.taxableAmount !== 'undefined' && tb.taxableAmount !== null) ? Number(tb.taxableAmount || 0) : Number((Number(order.total || 0) - taxAmount).toFixed(2))

            .mb-3
              if hasAdjustment
                p.text-end.mb-1
                  span.text-white #{isPremiumAdj ? 'Premium Applied:' : 'Discount Applied:'}
                  strong.ms-2 #{discountApplied || (isPremiumAdj ? 'Premium' : 'Discount')}
                p.text-end.mb-1
                  span.text-white Total before adjustment:
                  strong.ms-2 GH₵ #{Number(totalBeforeDiscount || 0).toFixed(2)}
                p.text-end.mb-1
                  span.text-white #{isPremiumAdj ? 'Premium:' : 'Discount:'}
                  strong.text-white.ms-2 #{isPremiumAdj ? '+ GH₵ ' : '- GH₵ '}#{Math.abs(Number(order.discountAmount || 0)).toFixed(2)}

              if hasTax
                p.text-end.mb-1
                  span.text-white VATable amount:
                  strong.ms-2 GH₵ #{Number(taxableAmount || 0).toFixed(2)}
                p.text-end.mb-1
                  span.text-white VAT:
                  strong.text-white.ms-2 + GH₵ #{taxAmount.toFixed(2)}

              p.text-end.mb-1
                span.text-white Total:
                strong.ms-2 GH₵ #{Number(order.total || 0).toFixed(2)}
              p.text-end.mb-1
                span.text-white Paid so far:
                strong.ms-2 GH₵ #{Number(paidSoFar || 0).toFixed(2)}
              p.text-end.mb-1
                span.text-white Remaining:
                if outstanding > 0
                  strong.ms-2 GH₵ #{Number(outstanding || 0).toFixed(2)}
                else
                  strong.ms-2 GH₵ 0.00

            // Payment history
            h6.mb-2.text-white Payment History
            if order.payments && order.payments.length
              .table-responsive
                table.table.table-sm.table-striped
                  thead
                    tr
                      th Date
                      th Method
                      th.text-end Amount
                      th Details
                      th Note
                  tbody
                    each p in order.payments
                      - var dt = ''
                      - try { dt = p.createdAt ? new Date(p.createdAt).toLocaleString() : '' } catch (e) { dt = '' }
                      - var method = String(p.method || 'unknown').toLowerCase()
                      - var amount = Number(p.amount || 0).toFixed(2)
                      - var meta = (p.meta && typeof p.meta === 'object') ? p.meta : {}
                      - var paymentName = p.cashBookName || meta.cashBookName || String(method).toUpperCase()
                      - var knownKeys = ['momoNumber','momoTxId','chequeNumber','depositDetails','cashBookId','cashBookName','cashBookKind','receivedAmount','creditExcess']
                      - var extraMeta = {}
                      - var keys = Object.keys(meta || {})
                      - for (var k = 0; k < keys.length; k++) {
                      -   var kk = keys[k]
                      -   if (knownKeys.indexOf(kk) === -1) extraMeta[kk] = meta[kk]
                      - }

                      tr
                        td #{dt}
                        td #{paymentName}
                        td.text-end GH₵ #{amount}
                        td
                          if method === 'momo'
                            if meta.momoNumber
                              div.mb-1
                                small.text-muted-light Number:
                                span.ms-2 #{meta.momoNumber}
                            if meta.momoTxId
                              div
                                small.text-muted-light TxID:
                                span.ms-2 #{meta.momoTxId}
                          else if method === 'cheque' || method === 'bank'
                            if meta.chequeNumber
                              div.mb-1
                                small.text-muted-light Cheque:
                                span.ms-2 #{meta.chequeNumber}
                            if meta.depositDetails
                              div
                                small.text-muted-light Deposit:
                                span.ms-2 #{meta.depositDetails}
                          if meta.receivedAmount && Number(meta.receivedAmount || 0) !== Number(p.amount || 0)
                            div.mt-1
                              small.text-muted-light Received:
                              span.ms-2 GH₵ #{Number(meta.receivedAmount || 0).toFixed(2)}

                          - var extraKeys = Object.keys(extraMeta)
                          if extraKeys.length
                            div.mt-1
                              each val, key in extraMeta
                                div
                                  small.text-muted-light #{key}:
                                  span.ms-2 #{val}

                          if p.recordedBy && (typeof p.recordedBy === 'object') && (p.recordedBy.name || p.recordedBy.username)
                            div.mt-2
                              small.text-muted-light Recorded by:
                              span.ms-2 #{p.recordedBy.name || p.recordedBy.username}
                          else if p.recordedByName
                            div.mt-2
                              small.text-muted-light Recorded by:
                              span.ms-2 #{p.recordedByName}

                        td #{p.note || ''}
            else
              p.text-muted-light No payments recorded.

            // Actions (record payment -> jumps to /orders/pay with id)
            .d-flex.justify-content-end.mt-3
              - var orderIdEncoded = encodeURIComponent(order.orderId || '')
              if outstanding > 0
                a.btn.btn-sm.btn-primary(href=`/orders/pay?orderId=${orderIdEncoded}`) Update
